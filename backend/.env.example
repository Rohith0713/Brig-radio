# ============================================
#  Brig Radio — Environment Variables
# ============================================
# Copy this file to .env on your server and fill in real values.
# NEVER commit .env with real credentials to git.

# ── Flask ─────────────────────────────────────
FLASK_APP=wsgi.py
FLASK_ENV=production

# ── Database (AWS RDS MySQL) ──────────────────
DB_HOST=your-rds-endpoint.xxxx.ap-south-1.rds.amazonaws.com
DB_USER=your_rds_username
DB_PASSWORD=your_rds_password
DB_NAME=campuswave

# ── Security Keys ─────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_STRING
JWT_SECRET_KEY=CHANGE_ME_TO_A_DIFFERENT_RANDOM_STRING

# ── File Uploads ──────────────────────────────
# Absolute path recommended for production
UPLOAD_FOLDER=/home/ubuntu/brigradio/backend/uploads
MAX_CONTENT_LENGTH=524288000

# ── Email (Gmail App Password) ────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here

# ── Gunicorn (optional overrides) ─────────────
# GUNICORN_BIND=0.0.0.0:8000
# GUNICORN_WORKERS=3
